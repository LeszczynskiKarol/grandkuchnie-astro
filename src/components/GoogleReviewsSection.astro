---
// GoogleReviewsSection.astro
//
// Dane pochodzą z wizytówki Google *Grand Kuchnie* (place_id ChIJdwELFE41A0cRgSWfA_vdwuo),
// pobierane przez Places API (New) skryptem `npm run reviews:refresh`.
// Wcześniej były tu ręcznie wklejone opinie wizytówki MebleSystem — trzy z nich
// dosłownie nazywały tamtą firmę, a ocena 4,9 / 109 opinii też należała do niej.
//
// ⚠ ODŚWIEŻANIE JEST OBOWIĄZKOWE, NIE OPCJONALNE.
// Zasady Places API zabraniają cache'owania i przechowywania treści; jedynym polem
// zwolnionym z zakazu jest place_id (można trzymać bezterminowo). Ten JSON to snapshot,
// więc musi być regularnie odświeżany — inaczej łamiemy warunki i pokazujemy nieaktualną
// ocenę. W pełni zgodne alternatywy, jeśli chcesz uciec od snapshotu:
//   a) fetch po stronie klienta przez własny proxy (klucz zostaje na serwerze),
//   b) widget Place Details z Places UI Kit — Google sam ogarnia atrybucję i świeżość.
// https://developers.google.com/maps/documentation/places/web-service/policies

import placeData from '../data/google-reviews.json';

const reviews = placeData.reviews ?? [];

const TOTAL_RATING: number | null = placeData.rating ?? null;
const TOTAL_REVIEWS: number | null = placeData.userRatingCount ?? null;
const hasAggregate = TOTAL_RATING !== null && TOTAL_REVIEWS !== null && reviews.length > 0;

// Stabilny link do wizytówki. NIE podmieniaj go na URL skopiowany z paska adresu
// Google — takie linki niosą parametry sesyjne (sca_esv, sxsrf, ved, rlz, biw, bih,
// dpr), które wygasają. Ta forma jest trwała.
const GOOGLE_REVIEWS_URL =
  placeData.googleMapsUri ?? 'https://www.google.com/maps?cid=16916327220524295553';

// Google wymaga daty publikacji przy wyświetlaniu opinii — pokazujemy opis względny
// („3 miesiące temu") z API, z datą bezwzględną w atrybucie datetime.
const formatDate = (iso: string | null) =>
  iso ? new Date(iso).toLocaleDateString('pl-PL') : '';

const TRUNCATE_LENGTH_DESKTOP = 120;
const TRUNCATE_LENGTH_MOBILE = 200;
---

<section class="py-16 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4">
    <h2 class="text-3xl font-bold text-center text-secondary mb-12">
      Jak nas oceniają klienci?
    </h2>
    
    <div>
      <!-- Rating summary — tylko gdy znamy liczby z wizytówki Grand Kuchnie -->
      {hasAggregate && (
        <div class="text-center mb-8">
          <div class="text-4xl font-bold text-primary">
            {TOTAL_RATING!.toFixed(1)}
          </div>
          <div class="flex justify-center gap-1 my-2">
            {[...Array(5)].map((_, i) => (
              <svg
                class={`w-6 h-6 ${i < Math.round(TOTAL_RATING!) ? 'text-yellow-400 fill-current' : 'text-gray-300'}`}
                viewBox="0 0 24 24"
              >
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
            ))}
          </div>
          <div class="flex items-center justify-center gap-2 text-gray-600">
            <span>Na podstawie {TOTAL_REVIEWS} opinii</span>
            <img
              src="https://www.google.com/images/branding/googlelogo/2x/googlelogo_color_92x30dp.png"
              alt="Google"
              class="h-5"
            />
          </div>
        </div>
      )}

      <!-- Desktop - all reviews in one row (liczba kolumn = liczba opinii) -->
      <div
        class="hidden lg:grid gap-4 mb-8"
        style={`grid-template-columns: repeat(${reviews.length}, minmax(0, 1fr));`}
      >
        {reviews.map((review) => (
          <div class="p-4 bg-white rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-300 flex flex-col" data-review-id={review.id}>
            <div class="flex items-center gap-2 mb-3">
              <div class="w-9 h-9 rounded-full overflow-hidden bg-primary/10 flex items-center justify-center shrink-0">
                {review.authorPhoto ? (
                  <img src={review.authorPhoto} alt={review.author} loading="lazy" width="36" height="36" class="w-full h-full object-cover" />
                ) : (
                  <span class="text-primary font-semibold text-sm">{review.author.charAt(0)}</span>
                )}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="font-semibold text-sm truncate">
                  {review.authorUri ? (
                    <a href={review.authorUri} target="_blank" rel="noopener noreferrer nofollow" class="hover:text-primary">{review.author}</a>
                  ) : review.author}
                </h3>
                <div class="flex gap-0.5">
                  {[...Array(5)].map((_, i) => (
                    <svg
                      class={`w-3 h-3 ${i < review.rating ? 'text-yellow-400 fill-current' : 'text-gray-300'}`}
                      viewBox="0 0 24 24"
                    >
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                    </svg>
                  ))}
                </div>
              </div>
            </div>
            
            <!-- Text with expand/collapse -->
            <div class="flex-1">
              <p class="text-gray-600 text-sm review-text-short">
                {review.text.length > TRUNCATE_LENGTH_DESKTOP 
                  ? review.text.slice(0, TRUNCATE_LENGTH_DESKTOP) + '...' 
                  : review.text}
              </p>
              <p class="text-gray-600 text-sm review-text-full hidden">
                {review.text}
              </p>
              {review.text.length > TRUNCATE_LENGTH_DESKTOP && (
                <button 
                  class="text-primary hover:text-primary/80 text-xs font-medium mt-2 toggle-review-btn"
                  data-expanded="false"
                >
                  Rozwiń
                </button>
              )}
            </div>
            
            <p class="mt-3 text-xs text-gray-400">
              <a href={review.googleMapsUri ?? GOOGLE_REVIEWS_URL} target="_blank" rel="noopener noreferrer nofollow" class="hover:text-primary">
                <time datetime={review.publishTime ?? undefined}>{review.relativeTime ?? formatDate(review.publishTime)}</time>
              </a>
            </p>
          </div>
        ))}
      </div>

      <!-- Mobile/Tablet - reviews stacked -->
      <div class="lg:hidden grid grid-cols-1 md:grid-cols-2 gap-6">
        {reviews.map((review) => (
          <div class="p-6 bg-white rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-300" data-review-id={review.id}>
            <div class="flex items-center gap-4 mb-4">
              <div class="w-10 h-10 rounded-full overflow-hidden bg-primary/10 flex items-center justify-center shrink-0">
                {review.authorPhoto ? (
                  <img src={review.authorPhoto} alt={review.author} loading="lazy" width="40" height="40" class="w-full h-full object-cover" />
                ) : (
                  <span class="text-primary font-semibold">{review.author.charAt(0)}</span>
                )}
              </div>
              <div class="flex-1">
                <h3 class="font-semibold">
                  {review.authorUri ? (
                    <a href={review.authorUri} target="_blank" rel="noopener noreferrer nofollow" class="hover:text-primary">{review.author}</a>
                  ) : review.author}
                </h3>
                <div class="flex gap-1">
                  {[...Array(5)].map((_, i) => (
                    <svg
                      class={`w-4 h-4 ${i < review.rating ? 'text-yellow-400 fill-current' : 'text-gray-300'}`}
                      viewBox="0 0 24 24"
                    >
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                    </svg>
                  ))}
                </div>
              </div>
            </div>
            
            <!-- Text with expand/collapse -->
            <div>
              <p class="text-gray-600 review-text-short">
                {review.text.length > TRUNCATE_LENGTH_MOBILE 
                  ? review.text.slice(0, TRUNCATE_LENGTH_MOBILE) + '...' 
                  : review.text}
              </p>
              <p class="text-gray-600 review-text-full hidden">
                {review.text}
              </p>
              {review.text.length > TRUNCATE_LENGTH_MOBILE && (
                <button 
                  class="text-primary hover:text-primary/80 text-sm font-medium mt-2 toggle-review-btn"
                  data-expanded="false"
                >
                  Rozwiń
                </button>
              )}
            </div>
            
            <p class="mt-3 text-sm text-gray-400">
              <a href={review.googleMapsUri ?? GOOGLE_REVIEWS_URL} target="_blank" rel="noopener noreferrer nofollow" class="hover:text-primary">
                <time datetime={review.publishTime ?? undefined}>{review.relativeTime ?? formatDate(review.publishTime)}</time>
              </a>
            </p>
          </div>
        ))}
      </div>

      <!-- Zobacz wszystkie opinie button -->
      <div class="text-center mt-10">
        <a 
          href={GOOGLE_REVIEWS_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-secondary hover:bg-secondary/90 text-white font-semibold rounded-full transition-all hover:scale-105"
        >
          <img 
            src="https://www.google.com/favicon.ico" 
            alt="Google" 
            class="w-5 h-5"
          />
          Zobacz wszystkie opinie
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  // Toggle review expand/collapse
  document.querySelectorAll('.toggle-review-btn').forEach(btn => {
    btn.addEventListener('click', function(this: HTMLButtonElement) {
      const card = this.closest('[data-review-id]');
      if (!card) return;
      
      const shortText = card.querySelector('.review-text-short');
      const fullText = card.querySelector('.review-text-full');
      const isExpanded = this.dataset.expanded === 'true';
      
      if (isExpanded) {
        // Collapse
        shortText?.classList.remove('hidden');
        fullText?.classList.add('hidden');
        this.textContent = 'Rozwiń';
        this.dataset.expanded = 'false';
      } else {
        // Expand
        shortText?.classList.add('hidden');
        fullText?.classList.remove('hidden');
        this.textContent = 'Zwiń';
        this.dataset.expanded = 'true';
      }
    });
  });
</script>