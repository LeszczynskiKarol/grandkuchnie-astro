---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { 
  title, 
  description = 'Kuchnie na wymiar - projektowanie, produkcja, montaż. Grand Kuchnie - profesjonalne meble kuchenne w województwie kujawsko-pomorskim.',
  ogImage = '/img/og-image.jpg'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// GTM ID z oryginalnego projektu Next.js
const GTM_ID = 'GTM-5S7T7F2G';
---

<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  
  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL} />
  
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="pl_PL" />
  <meta property="og:site_name" content="Grand Kuchnie" />
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  
  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/img/favicon.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/img/favicon.png" />
  <link rel="apple-touch-icon" href="/img/favicon.png" />
  
  <title>{title}</title>
  
  <!-- Google Consent Mode v2 - MUSI BYĆ PRZED GTM -->
  <script is:inline define:vars={{ GTM_ID }}>
    // Inicjalizacja dataLayer
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    
    // Domyślne ustawienia zgód - wszystko zablokowane przed zgodą użytkownika
    gtag('consent', 'default', {
      'ad_storage': 'denied',
      'ad_user_data': 'denied',
      'ad_personalization': 'denied',
      'analytics_storage': 'denied',
      'functionality_storage': 'denied',
      'personalization_storage': 'denied',
      'security_storage': 'granted',
      'region': ['PL', 'EU'],
      'wait_for_update': 2000
    });
    
    // Dodatkowe ustawienia dla EU
    gtag('set', 'ads_data_redaction', true);
    gtag('set', 'url_passthrough', true);
    
    // Event inicjalizacji konsentu
    dataLayer.push({'event': 'consent_initialized'});
  </script>
  
  <!-- Google Tag Manager -->
  <script is:inline define:vars={{ GTM_ID }}>
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer', GTM_ID);
  </script>
  <!-- End Google Tag Manager -->
</head>

<body class="min-h-screen flex flex-col">
  <!-- Google Tag Manager (noscript) -->
  <noscript>
    <iframe 
      src={`https://www.googletagmanager.com/ns.html?id=${GTM_ID}`}
      height="0" 
      width="0" 
      style="display:none;visibility:hidden">
    </iframe>
  </noscript>
  <!-- End Google Tag Manager (noscript) -->
  
  <slot />
  
  <!-- Przywróć zapisane zgody z localStorage -->
  <script is:inline>
    (function() {
      // Funkcja gtag musi być dostępna
      function gtag(){dataLayer.push(arguments);}
      
      var saved = localStorage.getItem('consentSettings');
      if (saved) {
        try {
          var settings = JSON.parse(saved);
          gtag('consent', 'update', settings);
          
          // Wyślij event informujący o przywróceniu zgód
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            'event': 'consent_restored',
            'consent_changed': true
          });
          
          console.log('[Consent] Restored from localStorage:', settings);
        } catch(e) {
          console.error('[Consent] Error restoring consent:', e);
        }
      }
    })();
  </script>
</body>
</html>
