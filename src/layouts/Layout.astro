---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'Kuchnie na wymiar - projektowanie, produkcja, montaż. Grand Kuchnie - profesjonalne meble kuchenne w województwie kujawsko-pomorskim.',
  ogImage = '/img/og-image.jpg',
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site).toString();

// Tagi ladowane bezposrednio przez gtag.js (bez GTM — cala konfiguracja w kodzie):
// GA4: property "GrandKuchnie 2026 (czyste)" properties/546178771
// AW:  konwersje Google Ads (formularz IIukCPrJ180aEL_JkNcD, telefon YQkUCNjx1s0aEL_JkNcD)
const GA4_ID = 'G-7PC4J6DTTW';
const ADS_ID = 'AW-988030143';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Grand Kuchnie',
  image: 'https://www.grandkuchnie.pl/img/logo.webp',
  '@id': 'https://www.grandkuchnie.pl/#localbusiness',
  url: 'https://www.grandkuchnie.pl',
  telephone: '+48576376567',
  email: 'kontakt@grandkuchnie.pl',
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'ul. Polna 134, hala nr 3',
    addressLocality: 'Toruń',
    addressRegion: 'kujawsko-pomorskie',
    postalCode: '87-100',
    addressCountry: 'PL',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 53.0378558,
    longitude: 18.6448634,
  },
  areaServed: [
    'Toruń',
    'Bydgoszcz',
    'Włocławek',
    'Grudziądz',
    'Inowrocław',
    'województwo kujawsko-pomorskie',
  ],
  identifier: [
    { '@type': 'PropertyValue', propertyID: 'NIP', value: '9562111620' },
    { '@type': 'PropertyValue', propertyID: 'REGON', value: '389437853' },
  ],
};
---

<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow, max-image-preview:large" />

  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content={ogType} />
  <meta property="og:locale" content="pl_PL" />
  <meta property="og:site_name" content="Grand Kuchnie" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />

  <!-- Preconnect do bucketa z obrazami realizacji/bloga (hero = LCP na podstronach) -->
  <link rel="preconnect" href="https://s3.eu-north-1.amazonaws.com" crossorigin />

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="96x96" href="/img/favicon.png" />
  <link rel="apple-touch-icon" sizes="192x192" href="/img/apple-touch-icon.png" />

  <title>{title}</title>

  <!-- LocalBusiness schema (na każdej stronie) -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

  <!-- Per-page schema injection (Article/BreadcrumbList/Blog itp.) -->
  <slot name="head" />
  
  <!-- Google Consent Mode v2 - MUSI BYĆ PRZED gtag.js -->
  <script is:inline>
    // Inicjalizacja dataLayer
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    
    // Domyślne ustawienia zgód - wszystko zablokowane przed zgodą użytkownika
    gtag('consent', 'default', {
      'ad_storage': 'denied',
      'ad_user_data': 'denied',
      'ad_personalization': 'denied',
      'analytics_storage': 'denied',
      'functionality_storage': 'denied',
      'personalization_storage': 'denied',
      'security_storage': 'granted',
      'region': ['PL', 'EU'],
      'wait_for_update': 2000
    });
    
    // Dodatkowe ustawienia dla EU
    gtag('set', 'ads_data_redaction', true);
    gtag('set', 'url_passthrough', true);
    
    // Event inicjalizacji konsentu
    dataLayer.push({'event': 'consent_initialized'});
    // gtag globalnie — uzywany przez lib/ga.ts i skrypty konwersji
    window.gtag = gtag;
  </script>

  <!-- Google tag (gtag.js) — GA4 + konwersje Ads, bez GTM -->
  <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
  <script is:inline define:vars={{ GA4_ID, ADS_ID }}>
    window.gtag('js', new Date());
    window.gtag('config', GA4_ID);
    window.gtag('config', ADS_ID); // zawiera conversion linker
  </script>
</head>

<body class="min-h-screen flex flex-col">
  <slot />
  
  <!-- Globalne sledzenie klikniec w telefon (delegacja: dziala tez dla linkow hydrowanych pozniej przez React) -->
  <script is:inline define:vars={{ ADS_ID }}>
    document.addEventListener('click', function (e) {
      var a = e.target && e.target.closest ? e.target.closest('a[href^="tel:"]') : null;
      if (!a || !window.gtag) return;
      window.gtag('event', 'phone_click', {
        event_category: 'engagement',
        event_label: 'phone_number_click',
      });
      window.gtag('event', 'conversion', {
        send_to: ADS_ID + '/YQkUCNjx1s0aEL_JkNcD',
        value: 1.0,
        currency: 'PLN',
      });
    });
  </script>

  <!-- Przywróć zapisane zgody z localStorage -->
  <script is:inline>
    (function() {
      // Funkcja gtag musi być dostępna
      function gtag(){dataLayer.push(arguments);}
      
      var saved = localStorage.getItem('consentSettings');
      if (saved) {
        try {
          var settings = JSON.parse(saved);
          gtag('consent', 'update', settings);
          
          // Wyślij event informujący o przywróceniu zgód
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({
            'event': 'consent_restored',
            'consent_changed': true
          });
          
          console.log('[Consent] Restored from localStorage:', settings);
        } catch(e) {
          console.error('[Consent] Error restoring consent:', e);
        }
      }
    })();
  </script>
</body>
</html>
