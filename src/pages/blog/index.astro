---
// src/pages/blog/index.astro
import { getCollection } from "astro:content";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import Layout from "../../layouts/Layout.astro";

// Funkcja do tworzenia slug z kategorii
function slugify(text: string): string {
  const polishChars: Record<string, string> = {
    'ą': 'a', 'ć': 'c', 'ę': 'e', 'ł': 'l', 'ń': 'n',
    'ó': 'o', 'ś': 's', 'ź': 'z', 'ż': 'z',
    'Ą': 'a', 'Ć': 'c', 'Ę': 'e', 'Ł': 'l', 'Ń': 'n',
    'Ó': 'o', 'Ś': 's', 'Ź': 'z', 'Ż': 'z'
  };
  
  return text
    .toLowerCase()
    .split('')
    .map(char => polishChars[char] || char)
    .join('')
    .replace(/\s+/g, '-');
}

const allPosts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const posts = allPosts.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

// Wyróżnione posty
const featuredPosts = posts.filter(post => post.data.featured).slice(0, 3);

// Kategorie z liczbą artykułów
const categories = posts.reduce(
  (acc, post) => {
    const cat = post.data.category;
    acc[cat] = (acc[cat] || 0) + 1;
    return acc;
  },
  {} as Record<string, number>
);

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat("pl-PL", {
    year: "numeric",
    month: "short",
    day: "numeric",
  }).format(date);
};

const getReadingTime = (content: string) => {
  const words = content.split(/\s+/).length;
  return Math.ceil(words / 200);
};

// Schema.org dla strony bloga
const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Blog Grand Kuchnie",
  description: "Porady, inspiracje i trendy w projektowaniu kuchni na wymiar. Dowiedz się więcej o materiałach, aranżacjach i realizacjach.",
  url: "https://www.grandkuchnie.pl/blog",
  publisher: {
    "@type": "Organization",
    name: "Grand Kuchnie",
    logo: {
      "@type": "ImageObject",
      url: "https://www.grandkuchnie.pl/logo.png"
    }
  }
};
---

<Layout
  title="Blog kuchenny, poradnik o kuchniach | Grand Kuchnie - Porady i inspiracje"
  description="Porady, inspiracje i trendy w projektowaniu kuchni na wymiar. Materiały, aranżacje i realizacje kuchni w Toruniu i okolicach."
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(blogSchema)}
    slot="head"
  />

  <Header />

  <main class="pt-32 pb-20 bg-base-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Hero Section -->
      <header class="text-center mb-16">
        <span class="inline-block px-4 py-2 bg-primary/10 text-primary rounded-full text-sm font-medium mb-6">
          Blog
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-base-content mb-6">
          Porady i <span class="text-primary">inspiracje</span>
        </h1>
        <p class="text-lg sm:text-xl text-base-content/70 max-w-2xl mx-auto">
          Odkryj świat nowoczesnych kuchni na wymiar. Trendy, materiały, porady ekspertów i inspirujące realizacje.
        </p>
      </header>

      <!-- Kategorie -->
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        <a
          href="/blog"
          class="px-4 py-2 text-sm font-medium bg-primary text-primary-content rounded-full"
        >
          Wszystkie ({posts.length})
        </a>
        {Object.entries(categories).map(([category, count]) => (
          <a
            href={`/blog/kategoria/${slugify(category)}`}
            class="px-4 py-2 text-sm font-medium bg-base-200 border border-base-300 text-base-content/80 rounded-full hover:border-primary hover:text-primary transition-colors"
          >
            {category} ({count})
          </a>
        ))}
      </div>

      {/* Wyróżnione artykuły */}
      {featuredPosts.length > 0 && (
        <section class="mb-16">
          <h2 class="text-2xl font-bold text-base-content mb-8 flex items-center gap-2">
            <svg class="w-6 h-6 text-primary" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            Wyróżnione artykuły
          </h2>
          <div class="grid md:grid-cols-3 gap-6">
            {featuredPosts.map((post, index) => (
              <a
                href={`/blog/${post.slug}`}
                class={`group block bg-base-100 border border-base-200 rounded-2xl overflow-hidden hover:border-primary hover:shadow-xl transition-all ${index === 0 ? 'md:col-span-2 md:row-span-2' : ''}`}
              >
                {post.data.image ? (
                  <div class={`${index === 0 ? 'aspect-[16/9]' : 'aspect-video'} bg-base-200 overflow-hidden`}>
                    <img
                      src={post.data.image}
                      alt={post.data.imageAlt || post.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div class={`${index === 0 ? 'aspect-[16/9]' : 'aspect-video'} bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center`}>
                    <span class="text-6xl font-bold text-primary/30">
                      {post.data.title.substring(0, 2).toUpperCase()}
                    </span>
                  </div>
                )}
                <div class={`p-6 ${index === 0 ? 'md:p-8' : ''}`}>
                  <div class="flex items-center gap-2 mb-3">
                    <span class="px-2 py-0.5 text-xs font-medium bg-primary/10 text-primary rounded">
                      {post.data.category}
                    </span>
                    <span class="text-xs text-base-content/60">
                      {formatDate(post.data.publishDate)}
                    </span>
                  </div>
                  <h3 class={`${index === 0 ? 'text-2xl md:text-3xl' : 'text-lg'} font-bold text-base-content mb-2 group-hover:text-primary transition-colors line-clamp-2`}>
                    {post.data.title}
                  </h3>
                  <p class={`text-base-content/70 line-clamp-2 ${index === 0 ? 'text-base mb-4' : 'text-sm mb-3'}`}>
                    {post.data.description}
                  </p>
                  <div class="flex items-center justify-between text-sm">
                    <span class="text-base-content/60">
                      {getReadingTime(post.body || "")} min czytania
                    </span>
                    <span class="text-primary font-medium group-hover:translate-x-1 transition-transform">
                      Czytaj więcej →
                    </span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      {/* Wszystkie artykuły */}
      <section>
        <h2 class="text-2xl font-bold text-base-content mb-8">
          Wszystkie artykuły
        </h2>
        {posts.length === 0 ? (
          <div class="text-center py-16 bg-base-200 rounded-2xl">
            <div class="text-6xl mb-4">📝</div>
            <p class="text-base-content/70 text-lg mb-2">
              Artykuły pojawią się tutaj wkrótce.
            </p>
            <p class="text-base-content/50">
              Przygotowujemy dla Ciebie wartościowe treści o kuchniach na wymiar.
            </p>
          </div>
        ) : (
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {posts.map((post) => (
              <a
                href={`/blog/${post.slug}`}
                class="group block bg-base-100 border border-base-200 rounded-xl overflow-hidden hover:border-primary hover:shadow-lg transition-all"
              >
                {post.data.image ? (
                  <div class="aspect-video bg-base-200 overflow-hidden">
                    <img
                      src={post.data.image}
                      alt={post.data.imageAlt || post.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div class="aspect-video bg-gradient-to-br from-primary/10 to-secondary/10 flex items-center justify-center">
                    <span class="text-4xl font-bold text-primary/20">
                      {post.data.title.substring(0, 2).toUpperCase()}
                    </span>
                  </div>
                )}
                <div class="p-5">
                  <div class="flex items-center gap-2 mb-3">
                    <span class="px-2 py-0.5 text-xs font-medium bg-primary/10 text-primary rounded">
                      {post.data.category}
                    </span>
                    <span class="text-xs text-base-content/60">
                      {formatDate(post.data.publishDate)}
                    </span>
                  </div>
                  <h3 class="text-lg font-bold text-base-content mb-2 group-hover:text-primary transition-colors line-clamp-2">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-base-content/70 line-clamp-2 mb-3">
                    {post.data.description}
                  </p>
                  <div class="flex items-center justify-between text-sm">
                    <span class="text-base-content/60">
                      {getReadingTime(post.body || "")} min
                    </span>
                    <span class="text-primary font-medium">→</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}
      </section>

      {/* CTA Section */}
      <section class="mt-20 p-8 md:p-12 bg-gradient-to-br from-primary/10 to-secondary/10 rounded-3xl text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-base-content mb-4">
          Szukasz kuchni na wymiar?
        </h2>
        <p class="text-base-content/70 mb-8 max-w-xl mx-auto">
          Skontaktuj się z nami i otrzymaj bezpłatną wycenę. Realizujemy projekty w Toruniu, Bydgoszczy, Włocławku, Grudziądzu i całym województwie kujawsko-pomorskim.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/kontakt"
            class="inline-flex items-center justify-center gap-2 px-8 py-3 bg-primary text-primary-content rounded-xl hover:bg-primary/90 transition-colors font-semibold"
          >
            Bezpłatna wycena
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="/realizacje"
            class="inline-flex items-center justify-center gap-2 px-8 py-3 bg-base-100 border border-base-300 text-base-content rounded-xl hover:border-primary hover:text-primary transition-colors font-semibold"
          >
            Zobacz realizacje
          </a>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
