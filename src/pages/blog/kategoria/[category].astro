---
// src/pages/blog/kategoria/[category].astro
import { getCollection, type CollectionEntry } from "astro:content";
import Footer from "../../../components/Footer.astro";
import Header from "../../../components/Header.astro";
import Layout from "../../../layouts/Layout.astro";

type BlogCategory = CollectionEntry<"blog">["data"]["category"];

interface Props {
  categoryName: BlogCategory;
  posts: CollectionEntry<"blog">[];
}

// Funkcja do tworzenia slug z kategorii
function slugify(text: string): string {
  const polishChars: Record<string, string> = {
    'ą': 'a', 'ć': 'c', 'ę': 'e', 'ł': 'l', 'ń': 'n',
    'ó': 'o', 'ś': 's', 'ź': 'z', 'ż': 'z',
    'Ą': 'a', 'Ć': 'c', 'Ę': 'e', 'Ł': 'l', 'Ń': 'n',
    'Ó': 'o', 'Ś': 's', 'Ź': 'z', 'Ż': 'z'
  };
  
  return text
    .toLowerCase()
    .split('')
    .map(char => polishChars[char] || char)
    .join('')
    .replace(/\s+/g, '-');
}

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  // Funkcja slugify - musi być też tutaj (wewnątrz getStaticPaths)
  function slugify(text: string): string {
    const polishChars: Record<string, string> = {
      'ą': 'a', 'ć': 'c', 'ę': 'e', 'ł': 'l', 'ń': 'n',
      'ó': 'o', 'ś': 's', 'ź': 'z', 'ż': 'z',
      'Ą': 'a', 'Ć': 'c', 'Ę': 'e', 'Ł': 'l', 'Ń': 'n',
      'Ó': 'o', 'Ś': 's', 'Ź': 'z', 'Ż': 'z'
    };
    
    return text
      .toLowerCase()
      .split('')
      .map(char => polishChars[char] || char)
      .join('')
      .replace(/\s+/g, '-');
  }

  // WSZYSTKIE KATEGORIE - musi być WEWNĄTRZ getStaticPaths
  const ALL_CATEGORIES = [
    "Poradniki",
    "Trendy w kuchniach",
    "Materiały i wykończenia",
    "Aranżacje wnętrz",
    "Projektowanie kuchni",
    "Porady ekspertów",
    "Realizacje",
    "Łazienki i garderoby",
    "FAQ",
  ];

  return ALL_CATEGORIES.map((category) => ({
    params: { category: slugify(category) },
    props: {
      categoryName: category,
      posts: posts
        .filter((post) => post.data.category === category)
        .sort(
          (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
        ),
    },
  }));
}

const { categoryName, posts } = Astro.props;

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat("pl-PL", {
    year: "numeric",
    month: "short",
    day: "numeric",
  }).format(date);
};

const getReadingTime = (content: string) => {
  const words = content.split(/\s+/).length;
  return Math.ceil(words / 200);
};

// Opisy kategorii
const categoryDescriptions: Record<string, string> = {
  "Poradniki": "Praktyczne porady dotyczące planowania, projektowania i użytkowania kuchni na wymiar.",
  "Trendy w kuchniach": "Najnowsze trendy i style w projektowaniu nowoczesnych kuchni.",
  "Materiały i wykończenia": "Wszystko o materiałach: płyty laminowane, MDF lakierowany, akryl, fornir i blaty HPL.",
  "Aranżacje wnętrz": "Inspiracje i pomysły na aranżację kuchni w różnych stylach.",
  "Projektowanie kuchni": "Profesjonalne porady dotyczące ergonomii i funkcjonalności kuchni.",
  "Porady ekspertów": "Wiedza i doświadczenie naszych projektantów i stolarzy.",
  "Realizacje": "Prezentacje naszych najnowszych realizacji kuchni na wymiar.",
  "Łazienki i garderoby": "Porady i inspiracje dotyczące łazienek i garderób na wymiar.",
  "FAQ": "Odpowiedzi na najczęściej zadawane pytania o kuchnie na wymiar.",
};

// Ikony kategorii
const categoryIcons: Record<string, string> = {
  "Poradniki": "📚",
  "Trendy w kuchniach": "✨",
  "Materiały i wykończenia": "🪵",
  "Aranżacje wnętrz": "🎨",
  "Projektowanie kuchni": "📐",
  "Porady ekspertów": "💡",
  "Realizacje": "📸",
  "Łazienki i garderoby": "🚿",
  "FAQ": "❓",
};
---

<Layout
  title={`${categoryName} | Blog Grand Kuchnie`}
  description={categoryDescriptions[categoryName] || `Artykuły z kategorii ${categoryName}`}
>
  <Header />

  <main class="pt-32 pb-20 bg-base-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumbs -->
      <nav class="mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm text-base-content/60">
          <li>
            <a href="/" class="hover:text-primary transition-colors">
              Strona główna
            </a>
          </li>
          <li class="text-base-content/40">/</li>
          <li>
            <a href="/blog" class="hover:text-primary transition-colors">
              Blog
            </a>
          </li>
          <li class="text-base-content/40">/</li>
          <li class="text-base-content font-medium">{categoryName}</li>
        </ol>
      </nav>

      <!-- Header -->
      <header class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-4xl">{categoryIcons[categoryName] || "📝"}</span>
          <span class="inline-block px-4 py-2 bg-primary/10 text-primary rounded-full text-sm font-medium">
            Kategoria
          </span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold text-base-content mb-4">
          {categoryName}
        </h1>
        <p class="text-lg text-base-content/70 max-w-2xl">
          {categoryDescriptions[categoryName] || `Wszystkie artykuły z kategorii ${categoryName}`}
        </p>
        <div class="mt-4 text-sm text-base-content/60">
          {posts.length} {posts.length === 1 ? "artykuł" : posts.length < 5 ? "artykuły" : "artykułów"}
        </div>
      </header>

      {/* Lista artykułów */}
      {posts.length === 0 ? (
        <div class="text-center py-16 bg-base-200 rounded-2xl">
          <div class="text-6xl mb-4">{categoryIcons[categoryName] || "📝"}</div>
          <p class="text-base-content/70 text-lg mb-2">
            Artykuły z tej kategorii są w przygotowaniu.
          </p>
          <p class="text-base-content/50 mb-6">
            Wkrótce dodamy treści dotyczące: {categoryName}
          </p>
          <a
            href="/blog"
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-primary-content rounded-xl hover:bg-primary/90 transition-colors font-semibold"
          >
            ← Zobacz dostępne artykuły
          </a>
        </div>
      ) : (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="group block bg-base-100 border border-base-200 rounded-xl overflow-hidden hover:border-primary hover:shadow-lg transition-all"
            >
              {post.data.image ? (
                <div class="aspect-video bg-base-200 overflow-hidden">
                  <img
                    src={post.data.image}
                    alt={post.data.imageAlt || post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
              ) : (
                <div class="aspect-video bg-gradient-to-br from-primary/10 to-secondary/10 flex items-center justify-center">
                  <span class="text-4xl font-bold text-primary/20">
                    {post.data.title.substring(0, 2).toUpperCase()}
                  </span>
                </div>
              )}
              <div class="p-5">
                <div class="text-xs text-base-content/60 mb-3">
                  {formatDate(post.data.publishDate)}
                </div>
                <h2 class="text-lg font-bold text-base-content mb-2 group-hover:text-primary transition-colors line-clamp-2">
                  {post.data.title}
                </h2>
                <p class="text-sm text-base-content/70 line-clamp-2 mb-3">
                  {post.data.description}
                </p>
                <div class="flex items-center justify-between text-sm">
                  <span class="text-base-content/60">
                    {getReadingTime(post.body || "")} min
                  </span>
                  <span class="text-primary font-medium group-hover:translate-x-1 transition-transform">
                    →
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}

      {/* Powrót do bloga */}
      <div class="mt-12 text-center">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-primary hover:underline font-medium"
        >
          ← Wszystkie artykuły
        </a>
      </div>

      {/* CTA Section */}
      <section class="mt-16 p-8 bg-gradient-to-br from-primary/5 to-secondary/5 rounded-2xl border border-primary/10">
        <div class="text-center">
          <h2 class="text-2xl font-bold text-base-content mb-3">
            Potrzebujesz kuchni na wymiar?
          </h2>
          <p class="text-base-content/70 mb-6 max-w-lg mx-auto">
            Skontaktuj się z nami i otrzymaj bezpłatną wycenę. Działamy w Toruniu, Bydgoszczy i całym województwie kujawsko-pomorskim.
          </p>
          <a
            href="/kontakt"
            class="inline-flex items-center gap-2 px-8 py-3 bg-primary text-primary-content rounded-xl hover:bg-primary/90 transition-colors font-semibold"
          >
            Bezpłatna wycena
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
