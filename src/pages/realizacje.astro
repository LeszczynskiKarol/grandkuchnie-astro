---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent';
import { realizationCategories, realizations, getRealizationsByCategory } from '../data/realizations';

const sortedCategories = [...realizationCategories].sort((a, b) => a.order - b.order);
const allRealizations = realizations;
const PER_PAGE = 24;

const title = 'Realizacje kuchni na wymiar | Grand Kuchnie Toruń';
const description = 'Zobacz nasze realizacje kuchni na wymiar w Toruniu. Galeria zdjęć kuchni laminowanych, lakierowanych, akrylowych i fornirowanych.';
---

<Layout title={title} description={description}>
  <Header />

  <main class="min-h-screen bg-white">
    <!-- Page Header -->
    <section class="bg-secondary text-white py-16 text-center">
      <div class="max-w-7xl mx-auto px-4">
        <span class="inline-block text-primary text-sm font-bold uppercase tracking-widest mb-3">Portfolio</span>
        <h1 class="text-4xl lg:text-5xl font-bold mb-4">Nasze realizacje</h1>
        <p class="text-xl text-gray-300 max-w-2xl mx-auto">
          Każda kuchnia to osobna historia. Przeglądaj galerię naszych realizacji
          i znajdź inspirację dla swojego projektu.
        </p>
      </div>
    </section>

    <!-- Gallery Section -->
    <section class="py-12 px-4" id="gallerySection">
      <div class="max-w-7xl mx-auto">
        <!-- Category Filters -->
        <div class="flex flex-wrap gap-2 md:gap-3 mb-8 justify-center" id="categoryFilters">
          <button
            class="category-btn active"
            data-category="all"
          >
            Wszystkie <span class="cat-count">({allRealizations.length})</span>
          </button>
          {sortedCategories.map(cat => {
            const count = getRealizationsByCategory(cat.id).length;
            return (
              <button
                class="category-btn"
                data-category={cat.id.toString()}
              >
                {cat.name} <span class="cat-count">({count})</span>
              </button>
            );
          })}
        </div>

        <!-- Gallery Grid -->
        <div
          id="gallery"
          data-realizations={JSON.stringify(allRealizations)}
          data-per-page={PER_PAGE}
          data-slug-map={JSON.stringify(Object.fromEntries(realizationCategories.map(c => [c.slug, c.id.toString()])))}
        >
          <div id="galleryGrid" class="gallery-grid"></div>

          <!-- Pagination -->
          <div class="flex justify-center mt-10" id="paginationWrap"></div>
        </div>
      </div>
    </section>

    <!-- Lightbox Modal -->
    <div class="gallery-modal" id="galleryModal" role="dialog" aria-modal="true" aria-label="Powiększone zdjęcie">
      <div class="gallery-modal__overlay"></div>
      <div class="gallery-modal__content">
        <button class="gallery-modal__close" aria-label="Zamknij">
          <svg viewBox="0 0 24 24" class="w-7 h-7 fill-white"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
        </button>
        <div class="gallery-modal__counter">
          <span class="gallery-modal__current">1</span> / <span class="gallery-modal__total">1</span>
        </div>
        <button class="gallery-modal__nav gallery-modal__nav--prev" aria-label="Poprzednie zdjęcie">
          <svg viewBox="0 0 24 24" class="w-7 h-7 fill-white"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
        </button>
        <div class="gallery-modal__img-wrap">
          <img class="gallery-modal__img" src="" alt="Realizacja kuchni" />
        </div>
        <button class="gallery-modal__nav gallery-modal__nav--next" aria-label="Następne zdjęcie">
          <svg viewBox="0 0 24 24" class="w-7 h-7 fill-white"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
        </button>
        <div class="gallery-modal__thumbs" id="modalThumbnails"></div>
      </div>
    </div>

    <!-- CTA Section -->
    <section class="py-16 bg-secondary text-white">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-4">Podoba Ci się to, co widzisz?</h2>
        <p class="text-xl mb-8 text-gray-300 max-w-xl mx-auto">
          Skontaktuj się z nami, opowiedz o swoich potrzebach.
          Zrobimy dla Ciebie coś równie dobrego – albo lepszego.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+48576376567" class="btn btn-primary btn-lg gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
            576 376 567
          </a>
          <a href="mailto:kontakt@grandkuchnie.pl" class="btn btn-outline border-white/30 text-white hover:bg-white/10 btn-lg">
            kontakt@grandkuchnie.pl
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <CookieConsent client:load />
</Layout>

<!-- ============================================================
     is:global — bo Astro scoped styles NIE DZIAŁAJĄ na elementy
     tworzone dynamicznie przez JS (brak data-astro-cid-xxx)
     ============================================================ -->
<style is:global>
  /* ===== Category Filters ===== */
  .category-btn {
    padding: 0.5rem 1rem;
    border: 1px solid #e5e7eb;
    border-radius: 9999px;
    background: #fff;
    cursor: pointer;
    font-size: 0.875rem;
    font-family: inherit;
    color: #374151;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }
  @media (min-width: 768px) {
    .category-btn {
      padding: 0.625rem 1.25rem;
      font-size: 0.9375rem;
    }
  }
  .category-btn:hover {
    border-color: #fcbb42;
    color: #b8860b;
  }
  .category-btn.active {
    background: #fcbb42;
    border-color: #fcbb42;
    color: #181b55;
    font-weight: 600;
  }
  .cat-count {
    font-size: 0.75rem;
    opacity: 0.6;
  }

  /* ===== Gallery Grid ===== */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }
  @media (min-width: 640px) {
    .gallery-grid { grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
  }
  @media (min-width: 1024px) {
    .gallery-grid { grid-template-columns: repeat(4, 1fr); gap: 1rem; }
  }

  /* Gallery items — JS-created, MUST be global */
  .gallery-item {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 0.5rem;
    cursor: pointer;
    background: #f3f4f6;
  }
  .gallery-item img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }
  .gallery-item:hover img {
    transform: scale(1.05);
  }

  /* ===== Pagination (DaisyUI join) ===== */
  .pagination-join {
    display: inline-flex;
  }
  .pagination-join .join-item {
    border-radius: 0 !important;
  }
  .pagination-join .join-item:first-child {
    border-top-left-radius: 0.5rem !important;
    border-bottom-left-radius: 0.5rem !important;
  }
  .pagination-join .join-item:last-child {
    border-top-right-radius: 0.5rem !important;
    border-bottom-right-radius: 0.5rem !important;
  }

  /* ===== Lightbox Modal ===== */
  .gallery-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    background: rgba(0, 0, 0, 0.95);
  }
  .gallery-modal.active {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .gallery-modal__overlay {
    position: absolute;
    inset: 0;
  }
  .gallery-modal__content {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 20px 90px;
  }
  .gallery-modal__close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 44px;
    height: 44px;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background 0.2s;
  }
  .gallery-modal__close:hover {
    background: rgba(255, 255, 255, 0.2);
  }
  .gallery-modal__counter {
    position: absolute;
    top: 16px;
    left: 16px;
    color: #fff;
    background: rgba(0, 0, 0, 0.5);
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 0.9375rem;
    z-index: 10;
    user-select: none;
  }
  .gallery-modal__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 52px;
    height: 52px;
    background: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.25s;
    z-index: 10;
  }
  .gallery-modal__nav:hover {
    background: rgba(255, 255, 255, 0.22);
  }
  .gallery-modal__nav--prev { left: 16px; }
  .gallery-modal__nav--next { right: 16px; }
  .gallery-modal__img-wrap {
    max-width: 100%;
    max-height: calc(100vh - 180px);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .gallery-modal__img {
    max-width: 100%;
    max-height: calc(100vh - 180px);
    object-fit: contain;
    border-radius: 4px;
  }
  .gallery-modal__thumbs {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    padding: 6px;
    background: rgba(0, 0, 0, 0.55);
    border-radius: 8px;
    max-width: 85vw;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .gallery-modal__thumbs::-webkit-scrollbar { display: none; }
  .gallery-modal__thumb {
    flex-shrink: 0;
    width: 72px;
    height: 54px;
    border-radius: 4px;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    opacity: 0.55;
    transition: opacity 0.2s, border-color 0.2s;
  }
  .gallery-modal__thumb:hover { opacity: 0.85; }
  .gallery-modal__thumb.active {
    border-color: #fcbb42;
    opacity: 1;
  }
  .gallery-modal__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 768px) {
    .gallery-modal__nav { width: 40px; height: 40px; }
    .gallery-modal__nav--prev { left: 8px; }
    .gallery-modal__nav--next { right: 8px; }
    .gallery-modal__content { padding: 50px 10px 80px; }
    .gallery-modal__thumb { width: 56px; height: 42px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const gallery = document.getElementById('gallery') as HTMLElement;
    const grid = document.getElementById('galleryGrid') as HTMLElement;
    const paginationWrap = document.getElementById('paginationWrap') as HTMLElement;
    const modal = document.getElementById('galleryModal') as HTMLElement;
    const filterBtns = document.querySelectorAll('.category-btn');
    const gallerySection = document.getElementById('gallerySection') as HTMLElement;

    if (!gallery || !modal || !grid || !paginationWrap) return;

    interface RealItem { id: number; imageUrl: string; categoryId: number; }

    const allRealizations: RealItem[] = JSON.parse(gallery.dataset.realizations || '[]');
    const PER_PAGE = parseInt(gallery.dataset.perPage || '24', 10);

    const modalImage = modal.querySelector('.gallery-modal__img') as HTMLImageElement;
    const currentSpan = modal.querySelector('.gallery-modal__current') as HTMLElement;
    const totalSpan = modal.querySelector('.gallery-modal__total') as HTMLElement;
    const thumbsContainer = modal.querySelector('.gallery-modal__thumbs') as HTMLElement;

    let activeCategory = 'all';
    let filtered: RealItem[] = [];
    let currentPage = 1;
    let totalPages = 1;
    let modalIndex = 0;
    const THUMB_WINDOW = 11;

    // Slug↔ID maps for URL-based filtering
    const slugMap: Record<string, string> = JSON.parse(gallery.dataset.slugMap || '{}');
    const idToSlug: Record<string, string> = {};
    for (const [slug, id] of Object.entries(slugMap)) {
      idToSlug[id] = slug;
    }

    // ===================== FILTERING =====================
    function applyFilter() {
      if (activeCategory === 'all') {
        filtered = allRealizations;
      } else {
        const catId = parseInt(activeCategory, 10);
        filtered = allRealizations.filter(r => r.categoryId === catId);
      }
      totalPages = Math.max(1, Math.ceil(filtered.length / PER_PAGE));
      currentPage = 1;
    }

    // ===================== RENDER GRID =====================
    function renderGrid() {
      const start = (currentPage - 1) * PER_PAGE;
      const pageItems = filtered.slice(start, start + PER_PAGE);

      grid.innerHTML = '';
      pageItems.forEach((r, i) => {
        const div = document.createElement('div');
        div.className = 'gallery-item';
        div.dataset.globalIndex = (start + i).toString();
        div.innerHTML = `<img src="${r.imageUrl}" alt="Realizacja ${r.id}" loading="lazy" />`;
        grid.appendChild(div);
      });
    }

    // ===================== PAGINATION =====================
    function getPageNumbers(): (number | '...')[] {
      if (totalPages <= 7) {
        return Array.from({ length: totalPages }, (_, i) => i + 1);
      }
      const pages: (number | '...')[] = [1];
      let lo = Math.max(2, currentPage - 1);
      let hi = Math.min(totalPages - 1, currentPage + 1);
      if (currentPage <= 3) { lo = 2; hi = Math.min(5, totalPages - 1); }
      if (currentPage >= totalPages - 2) { hi = totalPages - 1; lo = Math.max(2, totalPages - 4); }
      if (lo > 2) pages.push('...');
      for (let i = lo; i <= hi; i++) pages.push(i);
      if (hi < totalPages - 1) pages.push('...');
      pages.push(totalPages);
      return pages;
    }

    function renderPagination() {
      paginationWrap.innerHTML = '';
      if (totalPages <= 1) return;

      const join = document.createElement('div');
      join.className = 'pagination-join';

      // Helper to create a button
      function mkBtn(label: string, page: number | null, isActive: boolean, isDots: boolean, isDisabled: boolean) {
        const btn = document.createElement('button');
        btn.className = 'join-item btn btn-sm md:btn-md';
        if (isActive) btn.classList.add('btn-primary');
        if (isDots) { btn.classList.add('btn-disabled'); btn.textContent = '…'; }
        else btn.textContent = label;
        if (isDisabled) btn.classList.add('btn-disabled');
        if (!isActive && !isDots && !isDisabled && page !== null) {
          btn.addEventListener('click', () => goToPage(page));
        }
        return btn;
      }

      // « First
      join.appendChild(mkBtn('«', 1, false, false, currentPage === 1));
      // ‹ Prev
      join.appendChild(mkBtn('‹', currentPage - 1, false, false, currentPage === 1));

      // Page numbers
      for (const p of getPageNumbers()) {
        if (p === '...') {
          join.appendChild(mkBtn('…', null, false, true, false));
        } else {
          join.appendChild(mkBtn(p.toString(), p, p === currentPage, false, false));
        }
      }

      // › Next
      join.appendChild(mkBtn('›', currentPage + 1, false, false, currentPage === totalPages));
      // » Last
      join.appendChild(mkBtn('»', totalPages, false, false, currentPage === totalPages));

      paginationWrap.appendChild(join);
    }

    function goToPage(page: number) {
      if (page < 1 || page > totalPages || page === currentPage) return;
      currentPage = page;
      renderGrid();
      renderPagination();
      gallerySection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // ===================== FULL RENDER =====================
    function fullRender() {
      applyFilter();
      renderGrid();
      renderPagination();
    }

    // ===================== FILTERS =====================
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeCategory = btn.getAttribute('data-category') || 'all';

        // Update URL without reload
        const url = new URL(window.location.href);
        if (activeCategory === 'all') {
          url.searchParams.delete('category');
        } else {
          const slug = idToSlug[activeCategory];
          if (slug) url.searchParams.set('category', slug);
        }
        window.history.replaceState({}, '', url.toString());

        fullRender();
      });
    });

    // ===================== MODAL =====================
    function updateThumbnails() {
      thumbsContainer.innerHTML = '';
      const total = filtered.length;
      if (total === 0) return;

      const half = Math.floor(THUMB_WINDOW / 2);
      let start = Math.max(0, modalIndex - half);
      let end = Math.min(total, start + THUMB_WINDOW);
      if (end - start < THUMB_WINDOW) start = Math.max(0, end - THUMB_WINDOW);

      for (let i = start; i < end; i++) {
        const thumb = document.createElement('div');
        thumb.className = 'gallery-modal__thumb' + (i === modalIndex ? ' active' : '');
        thumb.innerHTML = `<img src="${filtered[i].imageUrl}" alt="" />`;
        const idx = i;
        thumb.addEventListener('click', () => modalGoTo(idx));
        thumbsContainer.appendChild(thumb);
      }

      const activeEl = thumbsContainer.querySelector('.active');
      if (activeEl) activeEl.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }

    function modalGoTo(index: number) {
      const total = filtered.length;
      if (total === 0) return;
      modalIndex = ((index % total) + total) % total;
      modalImage.src = filtered[modalIndex].imageUrl;
      currentSpan.textContent = (modalIndex + 1).toString();
      totalSpan.textContent = total.toString();
      updateThumbnails();
    }

    function openModal(globalIdx: number) {
      modalGoTo(globalIdx);
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.remove('active');
      document.body.style.overflow = '';
    }

    grid.addEventListener('click', (e) => {
      const item = (e.target as HTMLElement).closest('.gallery-item') as HTMLElement;
      if (!item) return;
      const globalIdx = parseInt(item.dataset.globalIndex || '0', 10);
      openModal(globalIdx);
    });

    modal.querySelector('.gallery-modal__close')?.addEventListener('click', closeModal);
    modal.querySelector('.gallery-modal__overlay')?.addEventListener('click', closeModal);
    modal.querySelector('.gallery-modal__nav--prev')?.addEventListener('click', () => modalGoTo(modalIndex - 1));
    modal.querySelector('.gallery-modal__nav--next')?.addEventListener('click', () => modalGoTo(modalIndex + 1));

    // Touch swipe
    let touchStartX = 0;
    let touchStartY = 0;
    modal.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].clientX;
      touchStartY = e.changedTouches[0].clientY;
    }, { passive: true });
    modal.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 50) {
        if (dx > 0) modalGoTo(modalIndex - 1);
        else modalGoTo(modalIndex + 1);
      }
    }, { passive: true });

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (!modal.classList.contains('active')) return;
      if (e.key === 'Escape') closeModal();
      if (e.key === 'ArrowLeft') modalGoTo(modalIndex - 1);
      if (e.key === 'ArrowRight') modalGoTo(modalIndex + 1);
    });

    // ===================== INIT =====================
    // Read ?category= from URL (slug like "lazienki-na-wymiar")
    const urlParams = new URLSearchParams(window.location.search);
    const urlCategory = urlParams.get('category');

    if (urlCategory && slugMap[urlCategory]) {
      const catId = slugMap[urlCategory];
      activeCategory = catId;
      // Activate correct filter button
      filterBtns.forEach(b => {
        b.classList.remove('active');
        if (b.getAttribute('data-category') === catId) {
          b.classList.add('active');
        }
      });
    }

    fullRender();
  });
</script>