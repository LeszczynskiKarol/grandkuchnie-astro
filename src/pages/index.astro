---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import KitchenTypesSection from '../components/KitchenTypesSection.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import ProcessSection from '../components/ProcessSection.astro';
import ServiceAreasSection from '../components/ServiceAreasSection.astro';
import GoogleReviewsSection from '../components/GoogleReviewsSection.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { torun } from '../data/cities';

// Toruń jest siedzibą firmy — to strona główna ma rankować na „kuchnie na wymiar toruń",
// nie osobna podstrona miejska (patrz komentarz w src/data/cities.ts).
const title = 'Kuchnie na wymiar Toruń — pracownia Grand Kuchnie';
const description = 'Kuchnie na wymiar z własnej pracowni w Toruniu — projekt, produkcja i montaż. Realizacje w Bydgoszczy, Włocławku, Grudziądzu i Inowrocławiu. Darmowa wycena.';

---

<Layout title={title} description={description}>
  <Header />
  
  <main class="min-h-screen bg-white">
    <!-- Hero Section -->
    <section class="pt-6 pb-16 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <h1 class="text-4xl lg:text-5xl font-bold text-secondary mb-6">
              Kuchnie na wymiar — Toruń i województwo kujawsko-pomorskie
            </h1>
            <p class="text-xl text-gray-600 mb-8">
              Zleć nam kompleksowe wykonanie - od projektu po realizację. Stworzymy Twoją wymarzoną przestrzeń!
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="/kontakt/" class="btn btn-primary btn-lg">
                Darmowa wycena
              </a>
              <a href="/realizacje/" class="btn btn-outline btn-lg">
                Zobacz realizacje
              </a>
            </div>
          </div>
          <div class="relative h-[400px] lg:h-[500px]">
            <HeroCarousel />
          </div>
        </div>
      </div>
    </section>

    <KitchenTypesSection />
    <FeaturesSection />
    <ProcessSection />

    <!-- Treść lokalna dla Torunia — przeniesiona z /miasto/torun/, które przekierowuje tutaj -->
    <section id="kuchnie-na-wymiar-torun" class="py-24 bg-gray-50 scroll-mt-24">
      <div class="max-w-7xl mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <h2 class="text-4xl font-bold text-secondary mb-6">
            {torun.heading}
          </h2>
          <p class="text-xl text-gray-600">
            {torun.lead}
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
          {torun.facts.map((fact) => (
            <div class="bg-white p-8 rounded-2xl h-full border-t-4 border-primary">
              <h3 class="text-lg font-bold text-secondary mb-3">{fact.title}</h3>
              <p class="text-gray-600">{fact.body}</p>
            </div>
          ))}
        </div>

        <div class="max-w-3xl mx-auto">
          <p class="text-lg text-gray-700 leading-relaxed">{torun.body}</p>
          <div class="mt-8 flex flex-col sm:flex-row gap-4">
            <a href="/kontakt/" class="btn btn-primary">Umów bezpłatny pomiar</a>
            <a href="/realizacje/" class="btn btn-outline">Zobacz nasze realizacje</a>
          </div>
        </div>
      </div>
    </section>

    <ServiceAreasSection />
    <GoogleReviewsSection />

    <!-- CTA Section -->
    <section class="py-16 bg-secondary text-white">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-6">
          Chcesz zlecić kuchnię na wymiar?
        </h2>
        <p class="text-xl mb-8 text-gray-300">
          Skontaktuj się z nami i uzyskaj bezpłatną wycenę!
        </p>
        <a href="/kontakt/" class="btn btn-primary btn-lg">
          Darmowa wycena
        </a>
      </div>
    </section>
  </main>

  <Footer />
  <CookieConsent />
</Layout>